datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id          String   @id @default(cuid())
  name        String
  nodes       ProjectNode[]
  accessCodes AccessCode[]
}

model ProjectNode {
  id        String   @id @default(cuid())
  name      String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  files     File[]
}

model File {
  id        String   @id @default(cuid())
  name      String
  url       String
  type      String
  nodeId    String
  node      ProjectNode @relation(fields: [nodeId], references: [id])
}

model AccessCode {
  id          String   @id @default(cuid())
  code        String   @unique
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
}
